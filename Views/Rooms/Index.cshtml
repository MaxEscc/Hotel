@model IEnumerable<HotelReservation.Models.Room>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lista de Habitaciones</title>
    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-4">
        <h1>Lista de Habitaciones</h1>
        <p>
            <a asp-action="Create" class="btn btn-primary">Crear Nueva Habitación</a>
        </p>
        <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.First().RoomType)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Price)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Description)</th>
                    <th>@Html.DisplayNameFor(model => model.First().IsAvailable)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Capacity)</th>
                    <th>@Html.DisplayNameFor(model => model.First().Size)</th>
                    <th>@Html.DisplayNameFor(model => model.First().ImageUrl)</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.RoomType)</td>
                        <td>@Html.DisplayFor(modelItem => item.Price)</td>
                        <td>@Html.DisplayFor(modelItem => item.Description)</td>
                        <td>@Html.DisplayFor(modelItem => item.IsAvailable)</td>
                        <td>@Html.DisplayFor(modelItem => item.Capacity)</td>
                        <td>@Html.DisplayFor(modelItem => item.Size)</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.RoomId">
                                <img src="@item.ImageUrl" alt="Room Image" class="img-thumbnail" style="width:100px;height:auto;" />
                            </a>
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.RoomId" class="btn btn-warning btn-sm">Editar</a>
                            <a asp-action="Details" asp-route-id="@item.RoomId" class="btn btn-info btn-sm">Detalles</a>
                            <a asp-action="Delete" asp-route-id="@item.RoomId" class="btn btn-danger btn-sm">Eliminar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
