@model IEnumerable<HotelReservation.Models.Room>

<h2>Habitaciones Disponibles</h2>

<div class="container mt-4">
    <div class="row">
        @foreach (var room in Model)
        {
            <div class="col-md-4 mb-3">
                <div class="card h-100">
                    <img src="@room.ImageUrl" class="card-img-top" alt="@room.RoomType" style="height: 200px; object-fit: cover;">
                    <div class="card-body">
                        <h5 class="card-title">@room.RoomType</h5>
                        <p class="card-text"><strong>Descripción:</strong> @room.Description</p>
                        <p class="card-text"><strong>Capacidad:</strong> @room.Capacity personas</p>
                        <p class="card-text"><strong>Tamaño:</strong> @room.Size</p>
                        <p class="card-text"><strong>Comodidades:</strong> @room.Amenities</p>
                        <p class="card-text"><strong>Precio por noche:</strong> @room.Price.ToString("C")</p>
                        <p class="card-text"><strong>Horario de Check-In:</strong> @room.CheckInTime.ToString(@"hh\:mm")</p>
                        <p class="card-text"><strong>Horario de Check-Out:</strong> @room.CheckOutTime.ToString(@"hh\:mm")</p>
                    </div>
                    <div class="card-footer">
                        <a asp-action="Reserve" asp-route-id="@room.RoomId" class="btn btn-primary btn-block">Reservar</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
